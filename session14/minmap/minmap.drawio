<mxfile host="Electron">
  <diagram name="Page-1" id="mBCN_uOhqza2HanwMzu_">
    <mxGraphModel dx="1880" dy="1528" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="LN9HyGXCly9dnHZv6pl1-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=3;fontStyle=1" value="SESSION 14:&lt;br&gt;&lt;b&gt;FUNCTION (HÀM)&lt;/b&gt;" vertex="1">
          <mxGeometry height="70" width="220" x="880" y="590" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 01: Tổng quan về Function&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Khái niệm:&lt;/b&gt; Là một khối mã lệnh độc lập, được đặt tên và chỉ chạy khi được gọi.&lt;br&gt;• &lt;b&gt;Lợi ích:&lt;/b&gt; Tái sử dụng mã nguồn (Don&#39;t Repeat Yourself - DRY), dễ quản lý, bảo trì và chia nhỏ dự án lớn.&lt;br&gt;• &lt;b&gt;Cú pháp định nghĩa:&lt;/b&gt; Dùng từ khóa &lt;b&gt;def&lt;/b&gt;&lt;br&gt;  &lt;i&gt;def ten_ham():&lt;/i&gt;&lt;br&gt;  &lt;i&gt;    # Khối lệnh xử lý&lt;/i&gt;&lt;br&gt;• &lt;b&gt;Cách gọi hàm:&lt;/b&gt; &lt;i&gt;ten_ham()&lt;/i&gt; (Phải có cặp ngoặc tròn)." vertex="1">
          <mxGeometry height="150" width="380" x="350" y="240" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-3" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="LN9HyGXCly9dnHZv6pl1-2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="520" />
              <mxPoint x="540" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 02: Parameter &amp;amp; Argument&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Parameter (Tham số):&lt;/b&gt; Biến được khai báo ở phần định nghĩa hàm (trong dấu ngoặc của &lt;i&gt;def&lt;/i&gt;).&lt;br&gt;• &lt;b&gt;Argument (Đối số):&lt;/b&gt; Giá trị thực tế truyền vào hàm khi thực hiện cuộc gọi.&lt;br&gt;• &lt;b&gt;Phân loại tham số:&lt;/b&gt;&lt;br&gt;  - &lt;i&gt;Positional arguments:&lt;/i&gt; Truyền theo đúng thứ tự.&lt;br&gt;  - &lt;i&gt;Keyword arguments:&lt;/i&gt; Truyền kèm tên biến (Ví dụ: &lt;i&gt;ham(b=2, a=1)&lt;/i&gt;).&lt;br&gt;  - &lt;i&gt;Default parameters:&lt;/i&gt; Tham số có giá trị mặc định (Ví dụ: &lt;i&gt;def ham(a=10):&lt;/i&gt; - Tham số mặc định phải đặt ở cuối cùng)." vertex="1">
          <mxGeometry height="180" width="410" x="1230" y="210" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-5" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="LN9HyGXCly9dnHZv6pl1-4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1220" y="520" />
              <mxPoint x="1435" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 03: Giá trị trả về (Return value)&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Từ khóa return:&lt;/b&gt; Dùng để thoát hàm và xuất một hoặc nhiều giá trị ra ngoài nơi gọi hàm.&lt;br&gt;• &lt;b&gt;Đặc điểm:&lt;/b&gt; Khi gặp lệnh &lt;i&gt;return&lt;/i&gt;, hàm sẽ &lt;b&gt;dừng ngay lập tức&lt;/b&gt;, mọi mã lệnh phía sau nó trong khối hàm đều bị bỏ qua.&lt;br&gt;• &lt;b&gt;Mặc định:&lt;/b&gt; Nếu hàm không có lệnh &lt;i&gt;return&lt;/i&gt;, Python sẽ tự động trả về giá trị &lt;i&gt;None&lt;/i&gt;.&lt;br&gt;• &lt;b&gt;Trả về nhiều giá trị:&lt;/b&gt; Ngăn cách bằng dấu phẩy (Ví dụ: &lt;i&gt;return a, b&lt;/i&gt; -&gt; Python đóng gói thành một Tuple)." vertex="1">
          <mxGeometry height="140" width="390" x="1250" y="555" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-7" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="LN9HyGXCly9dnHZv6pl1-6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1180" y="625" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 04: Phạm vi biến (Scope)&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Local Scope (Phạm vi cục bộ):&lt;/b&gt; Biến khai báo bên trong hàm. Chỉ có thể sử dụng nội bộ bên trong hàm đó, biến biến mất khi hàm kết thúc.&lt;br&gt;• &lt;b&gt;Global Scope (Phạm vi toàn cục):&lt;/b&gt; Biến khai báo ở luồng chính ngoài hàm. Có thể đọc được ở mọi nơi trong chương trình (kể cả trong hàm).&lt;br&gt;• &lt;b&gt;Từ khóa global:&lt;/b&gt; Đặt bên trong hàm khi bạn có nhu cầu &lt;b&gt;chỉnh sửa/ghi đè&lt;/b&gt; giá trị của một biến toàn cục (Ví dụ: &lt;i&gt;global x&lt;/i&gt;)." vertex="1">
          <mxGeometry height="130" width="400" x="340" y="545" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-9" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="LN9HyGXCly9dnHZv6pl1-8">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="810" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 05: Docstring &amp;amp; Best Practice&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Docstring (Chuỗi tài liệu):&lt;/b&gt; Dùng 3 dấu nháy kép &lt;b&gt;&quot;&quot;&quot;...&quot;&quot;&quot;&lt;/b&gt; đặt ngay dòng đầu tiên bên dưới tên hàm để giải thích chức năng, tham số đầu vào và giá trị trả về.&lt;br&gt;• &lt;b&gt;Quy tắc đặt tên hàm (Best Practice):&lt;/b&gt;&lt;br&gt;  - Tên hàm nên bắt đầu bằng một &lt;b&gt;động từ&lt;/b&gt; thể hiện hành động (Ví dụ: &lt;i&gt;calculate_total, send_email&lt;/i&gt;).&lt;br&gt;  - Sử dụng phong cách viết chữ thường phân cách bằng dấu gạch dưới &lt;b&gt;snake_case&lt;/b&gt;.&lt;br&gt;  - Giữ cho hàm ngắn gọn, tập trung xử lý đúng **một nhiệm vụ duy nhất** (Single Responsibility Principle)." vertex="1">
          <mxGeometry height="150" width="430" x="330" y="820" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-11" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="LN9HyGXCly9dnHZv6pl1-10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="780" y="720" />
              <mxPoint x="545" y="770" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=2;" value="&lt;b&gt;💡 MỞ RỘNG: THAM SỐ BIẾN THIÊN TRONG PYTHON&lt;/b&gt;&lt;br&gt;• &lt;b&gt;*args (Arbitrary Arguments):&lt;/b&gt; Cho phép truyền số lượng đối số vị trí tùy ý vào hàm. Gom lại thành một &lt;b&gt;Tuple&lt;/b&gt;.&lt;br&gt;• &lt;b&gt;**kwargs (Arbitrary Keyword Arguments):&lt;/b&gt; Cho phép truyền số lượng đối số dạng từ khóa tùy ý. Gom lại thành một &lt;b&gt;Dictionary&lt;/b&gt;." vertex="1">
          <mxGeometry height="90" width="430" x="1190" y="830" as="geometry" />
        </mxCell>
        <mxCell id="LN9HyGXCly9dnHZv6pl1-13" edge="1" parent="1" source="LN9HyGXCly9dnHZv6pl1-1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=1.5;strokeDasharray=3;" target="LN9HyGXCly9dnHZv6pl1-12">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1200" y="730" />
              <mxPoint x="1405" y="770" />
            </Array>
          </mxGeometry>
        </mxCell>
