<mxfile host="Electron">
  <diagram name="Page-1" id="oVayOauROUV9TpHhjqHl">
    <mxGraphModel dx="1051" dy="873" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="OIgXCzeOUputjjdpZgw--1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=3;fontStyle=1" value="SESSION 05:&lt;br&gt;&lt;b&gt;VÒNG LẶP NÂNG CAO&lt;/b&gt;" vertex="1">
          <mxGeometry height="70" width="220" x="710" y="485" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 01: break &amp;amp; continue&lt;/b&gt;&lt;br&gt;• &lt;b&gt;break:&lt;/b&gt; Lập tức thoát và kết thúc hoàn toàn vòng lặp hiện tại gần nó nhất.&lt;br&gt;• &lt;b&gt;continue:&lt;/b&gt; Bỏ qua các câu lệnh còn lại trong lượt lặp hiện tại, chuyển ngay sang lượt lặp tiếp theo.&lt;br&gt;👉 &lt;i&gt;Ứng dụng:&lt;/i&gt; Kiểm tra điều kiện dừng sớm hoặc lọc bỏ phần tử không thỏa mãn." vertex="1">
          <mxGeometry height="100" width="340" x="250" y="205" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--3" edge="1" parent="1" source="OIgXCzeOUputjjdpZgw--1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="OIgXCzeOUputjjdpZgw--2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="600" y="425" />
              <mxPoint x="420" y="365" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 02: Nested loop (Vòng lặp lồng nhau)&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Cơ chế:&lt;/b&gt; Một vòng lặp nằm hoàn toàn bên trong khối lệnh của một vòng lặp khác.&lt;br&gt;• &lt;b&gt;Cách chạy:&lt;/b&gt; Với mỗi &lt;u&gt;một lượt&lt;/u&gt; của vòng lặp ngoài, vòng lặp trong sẽ chạy &lt;u&gt;đầy đủ tất cả&lt;/u&gt; các lượt của nó.&lt;br&gt;• &lt;b&gt;Ứng dụng:&lt;/b&gt; Xử lý ma trận dữ liệu 2 chiều (hàng và cột), duyệt danh sách lồng." vertex="1">
          <mxGeometry height="110" width="360" x="1030" y="200" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--5" edge="1" parent="1" source="OIgXCzeOUputjjdpZgw--1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="OIgXCzeOUputjjdpZgw--4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="425" />
              <mxPoint x="1210" y="365" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 03: Vẽ pattern (*)&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Tư duy hình học:&lt;/b&gt;&lt;br&gt;  - Vòng lặp ngoài quản lý số thứ tự dòng (Hàng - i).&lt;br&gt;  - Vòng lặp trong quản lý số ký tự in ra trên dòng (Cột - j).&lt;br&gt;• &lt;b&gt;Kỹ thuật in không xuống dòng:&lt;/b&gt; Dùng tham số &lt;i&gt;print(&#39;*&#39;, end=&#39;&#39;)&lt;/i&gt;.&lt;br&gt;• Xuống dòng mới sau khi kết thúc vòng lặp con bằng lệnh &lt;i&gt;print()&lt;/i&gt;.&lt;br&gt;👉 &lt;i&gt;Bài toán kinh điển:&lt;/i&gt; Vẽ hình chữ nhật, hình tam giác sao, tam giác cân." vertex="1">
          <mxGeometry height="130" width="360" x="1050" y="515" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--7" edge="1" parent="1" source="OIgXCzeOUputjjdpZgw--1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="OIgXCzeOUputjjdpZgw--6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="565" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=1.5;" value="&lt;b&gt;Lesson 04: Tối ưu loop cơ bản&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Giảm thiểu tính toán thừa:&lt;/b&gt; Đưa các biểu thức cố định hoặc tính độ dài chuỗi/mảng ra ngoài trước khi khởi chạy vòng lặp.&lt;br&gt;• &lt;b&gt;Sử dụng break hợp lý:&lt;/b&gt; Dừng vòng lặp ngay khi đã tìm thấy kết quả mong muốn (ví dụ bài toán tìm kiếm, kiểm tra số nguyên tố).&lt;br&gt;• &lt;b&gt;Hạn chế lồng nhau quá sâu:&lt;/b&gt; Tránh độ phức tạp thuật toán tăng lũy thừa (O(N^2), O(N^3))." vertex="1">
          <mxGeometry height="120" width="380" x="210" y="500" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--9" edge="1" parent="1" source="OIgXCzeOUputjjdpZgw--1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=2;" target="OIgXCzeOUputjjdpZgw--8">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="555" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#ffffff;fontColor=#000000;strokeColor=#000000;strokeWidth=2;" value="&lt;b&gt;⚠️ LƯU Ý VỀ ĐỘ PHỨC TẠP (PERFORMANCE)&lt;/b&gt;&lt;br&gt;• Vòng lặp lồng nhau có số lượt chạy nhân cấp số nhân với nhau: &lt;b&gt;N × M&lt;/b&gt; lượt.&lt;br&gt;• Nếu mảng dữ liệu quá lớn, &lt;i&gt;Nested loop&lt;/i&gt; rất dễ làm chậm hoặc treo hệ thống.&lt;br&gt;• Luôn tư duy giải pháp tối ưu, dùng cấu trúc dữ liệu phù hợp để thay thế nếu có thể." vertex="1">
          <mxGeometry height="90" width="420" x="610" y="765" as="geometry" />
        </mxCell>
        <mxCell id="OIgXCzeOUputjjdpZgw--11" edge="1" parent="1" source="OIgXCzeOUputjjdpZgw--1" style="edgeStyle=curved=1;endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#FF0000;strokeWidth=1.5;strokeDasharray=3;" target="OIgXCzeOUputjjdpZgw--10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="655" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
